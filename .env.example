# PostgreSQL
POSTGRES_USER=microgreen
POSTGRES_PASSWORD=change_me
POSTGRES_DB=microgreen

# Telegram-бот (раскомментируй и заполни, чтобы включить уведомления и бота).
# Токен от @BotFather. Без него бот не стартует, а бэкенд просто молчит.
# BOT_TOKEN=123456789:AAExampleTokenFromBotFather
# Твой личный chat_id — кому падают уведомления о заказах. Узнать: команда /id в боте.
# ADMIN_CHAT_ID=123456789
# URL каталога для кнопки «Магазин» (на проде — публичный домен, под Mini App).
SHOP_URL=http://localhost:5173

# Админка. JWT_SECRET — длинная случайная строка (python -c "import secrets; print(secrets.token_urlsafe(48))").
# ADMIN_USERNAME/PASSWORD — первый админ, создаётся в БД при старте, если его ещё нет.
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
